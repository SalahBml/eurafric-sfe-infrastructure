[defaults]
host_key_checking = False
[ssh_connection]
ssh_args = -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null
inventory = inventory.ini
host_key_checking = False

[ssh_connection]
# Use the full path we just verified
ssh_executable = /usr/bin/ssh.exe
# Ensure the path to the key is exactly where it lives on Windows
ssh_args = -i C:/Users/Adam/.ssh/multipass_key -o StrictHostKeyChecking=no

# Do the same for SCP if needed
scp_executable = /mnt/c/Windows/System32/OpenSSH/scp.exe
